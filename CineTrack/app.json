{
  "expo": {
    "name": "CineTrack",
    "slug": "CineTrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cinetrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ios.CineTrack",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow CineTrack to access your camera to scan movie posters.",
        "NSCalendarsUsageDescription": "Allow CineTrack to add opening nights to your calendar."
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.android.CineTrack",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
   "plugins": [
      "expo-asset",
       "expo-sqlite",
      "./withAndroidGpuSupport.js",
      "./withCrashlyticsGradle.js",
      "./withCrashlyticsPodfile.js",
      "react-native-litert-lm",
      [
        "expo-calendar",
        {
          "calendarPermissionRationale": "Allow CineTrack to add movie opening nights to your calendar."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "kotlinVersion": "2.3.0"
          }
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
